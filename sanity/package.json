{
  "name": "belasica-studio",
  "version": "1.0.0",
  "private": true,
  "description": "FK Belasica — Sanity Studio (content home). Standalone package; not compiled by the Next.js app (D-1.02-1).",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "extract-schema": "sanity schema extract --enforce-required-fields --path schema.json",
    "typegen": "npm run extract-schema && sanity typegen generate"
  },
  "dependencies": {
    "@sanity/vision": "6.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "6.4.0",
    "styled-components": "6.4.3"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3"
  }
}
