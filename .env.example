# Belasica — environment variables (copy to .env.local and fill in; never commit real values).
# .env.local is git-ignored. The real values also live in Vercel (Production, Preview, Development).

# Sanity project & dataset — public identifiers, safe to expose to the browser.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=

# Sanity read token — Viewer role, SERVER-ONLY (no NEXT_PUBLIC_ prefix). Required to
# read the private datasets. Keep it out of the repo and out of client bundles.
SANITY_API_READ_TOKEN=

# Shared secret that authenticates the Sanity revalidation webhook (app/api/revalidate).
# Must be identical to the secret configured on the Sanity webhook.
SANITY_REVALIDATE_SECRET=
